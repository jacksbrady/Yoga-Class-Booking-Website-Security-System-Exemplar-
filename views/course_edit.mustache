{{> head}}
{{> header}}

<main class="wrap">

    <div class="edit-course-layout">
        <section class="edit-course-main">
            <h1>{{title}}</h1>

            <form method="POST" action="/organiser/courses/{{course.id}}/edit">
                <div class="form-group">
                    <label for="title">Course Title</label>
                    <input type="text" id="title" name="title" value="{{course.title}}" required />
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description">{{course.description}}</textarea>
                </div>

                <div class="form-group">
                    <label for="level">Level</label>
                    <select id="level" name="level" required>
                        <option value="beginner">Beginner</option>
                        <option value="intermediate">Intermediate</option>
                        <option value="advanced">Advanced</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="type">Type</label>
                    <select id="type" name="type" required>
                        <option value="WEEKLY_BLOCK">Weekly Block</option>
                        <option value="WEEKEND_WORKSHOP">Weekend Workshop</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>
                        <input type="checkbox" name="allowDropIn" {{#course.allowDropIn}} checked{{/course.allowDropIn}} />
                        Allow drop-in
                    </label>
                </div>

                <div class="form-group">
                    <label for="startDate">Start Date</label>
                    <input type="date" id="startDate" name="startDate" value="{{course.startDate}}" />
                </div>

                <div class="form-group">
                    <label for="endDate">End Date</label>
                    <input type="date" id="endDate" name="endDate" value="{{course.endDate}}" />
                </div>

                <button type="submit" class="btn primary">Save Course Changes</button>
            </form>

            <button type="button"
                    class="btn"
                    onclick="openDeleteCourseModal()">
                Delete Course
            </button>

            <div id="deleteCourseModal" class="modal hidden">
                <div class="modal-content">
                    <h2>Delete Course</h2>
                    <p>Are you sure you want to delete this course?</p>
                    <p>This will also remove all linked classes.</p>

                    <form method="POST" action="/organiser/courses/{{course.id}}/delete">
                        <button type="submit" class="btn primary">
                            Yes, Delete Course
                        </button>

                        <button type="button"
                                class="btn"
                                onclick="closeDeleteCourseModal()">
                            Cancel
                        </button>
                    </form>
                </div>
            </div>
        </section>

        <section class="edit-course-sessions">
            <h2>Classes / Sessions</h2>

            <p>
                <a href="/organiser/courses/{{course.id}}/sessions/new" class="btn primary">
                    Add New Class
                </a>
            </p>

            <table class="table">
                <thead>
                    <tr>
                        <th>Start</th>
                        <th>End</th>
                        <th>Capacity</th>
                        <th>Booked</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {{#sessions}}
                    <tr>
                        <td>{{startDateTime}}</td>
                        <td>{{endDateTime}}</td>
                        <td>{{capacity}}</td>
                        <td>{{bookedCount}}</td>
                        <td>
                            <form method="POST" action="/organiser/courses/{{course.id}}/sessions/{{id}}/delete">
                                <button type="submit" class="btn">Delete Session</button>
                            </form>
                        </td>
                    </tr>
                    {{/sessions}}

                    {{^sessions}}
                    <tr>
                        <td colspan="5">No sessions added yet.</td>
                    </tr>
                    {{/sessions}}
                </tbody>
            </table>
        </section>
    </div>

    <script src="/static/js/delete-course-modal.js"></script>

    {{> footer}}
